# ============================================================
# Realtime Log Analytics Platform — Environment Variables
# Copy to .env and fill in values before running docker compose
# ============================================================

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=application-logs

# --- Elasticsearch ---
ELASTICSEARCH_HOST=http://elasticsearch:9200
ELASTICSEARCH_INDEX=application-logs

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Service tunables ---
# Set to true to enable debug-level FastAPI error responses
DEBUG=false

# --- user_service ---
USER_SERVICE_HOST=0.0.0.0
USER_SERVICE_PORT=8001

# --- order_service ---
ORDER_SERVICE_HOST=0.0.0.0
ORDER_SERVICE_PORT=8002

# --- payment_service ---
PAYMENT_SERVICE_HOST=0.0.0.0
PAYMENT_SERVICE_PORT=8003

# --- analytics_api ---
ANALYTICS_API_HOST=0.0.0.0
ANALYTICS_API_PORT=8000
